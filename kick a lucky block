-- CHARACTER
local function getCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid")
    local hrp = char:WaitForChild("HumanoidRootPart")
    return char, hum, hrp
end

-- SAFE MOVETO
local function safeMoveTo(humanoid, hrp, position)
    humanoid:MoveTo(position)
    while true do
        if not humanoid or humanoid.Health <= 0 then
            return false
        end
        local distance = (hrp.Position - position).Magnitude
        if distance <= 5 then
            return true
        end
        humanoid:MoveTo(position)
        task.wait(0.2)
    end
end

-- FUNÇÃO PARA VERIFICAR SE O BOTÃO ESTÁ REALMENTE NA TELA
local function isButtonOnScreen(button)
    local pos = button.AbsolutePosition
    local size = button.AbsoluteSize
    local viewport = workspace.CurrentCamera.ViewportSize
    
    -- Verifica se o botão está dentro dos limites da tela
    local isOnScreen = (pos.X + size.X) > 0 and pos.X < viewport.X and
                       (pos.Y + size.Y) > 0 and pos.Y < viewport.Y and
                       size.X > 50 and size.Y > 30  -- Tamanho mínimo realista para botão de upgrade
    
    return isOnScreen
end

-- FUNÇÃO PARA CLICAR NO CENTRO REAL
local function clickRealButton(button)
    if not button or not button.Visible then
        return false
    end
    
    local pos = button.AbsolutePosition
    local size = button.AbsoluteSize
    
    -- Verifica tamanho realista (evita clicar em coisas minúsculas/invisíveis)
    if size.X < 50 or size.Y < 30 then
        return false
    end
    
    -- Centro exato
    local centerX = pos.X + (size.X / 2)
    local centerY = pos.Y + (size.Y / 2)
    
    -- Verifica se está na tela
    local viewport = workspace.CurrentCamera.ViewportSize
    if centerX < 0 or centerY < 0 or centerX > viewport.X or centerY > viewport.Y then
        return false
    end
    
    print("✅ CLICANDO:", button.Name, "| Centro:", math.floor(centerX), math.floor(centerY), "| Tamanho:", math.floor(size.X), "x", math.floor(size.Y))
    
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
    end)
    
    return true
end

