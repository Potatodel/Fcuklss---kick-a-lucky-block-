-- =========================================
-- CLICK BONUS - VERSÃO CORRIGIDA (SÓ CLICA EM BOTÕES REAIS)
-- =========================================

local clickBonus = false
local clickedButtons = {} -- Cache para evitar clicks repetidos

TabMain:Toggle({
    Title = "Click Bonus",
    Desc = "Clica no centro de botões REAIS (upgrades, loja, bonus)",
    Icon = "sparkles",
    Default = false,

    Callback = function(state)
        clickBonus = state
        if state then
            print("Click Bonus ACTIVATED - Modo corrigido")
            clickedButtons = {}
            
            task.spawn(function()
                while clickBonus do
                    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
                    
                    if playerGui then
                        -- Procura todos os botões
                        local allButtons = {}
                        for _, v in ipairs(playerGui:GetDescendants()) do
                            if (v:IsA("TextButton") or v:IsA("ImageButton")) and v.Visible then
                                table.insert(allButtons, v)
                            end
                        end
                        
                        -- Filtra e clica nos botões relevantes
                        for _, btn in ipairs(allButtons) do
                            if not clickBonus then break end
                            
                            local name = tostring(btn.Name):lower()
                            local text = ""
                            pcall(function() text = tostring(btn.Text):lower() end)
                            
                            -- Verifica se é botão de upgrade/loja/bonus
                            local isRelevant = string.find(name, "upgrade") or 
                                              string.find(name, "store") or 
                                              string.find(name, "shop") or
                                              string.find(name, "bonus") or
                                              string.find(name, "run") or
                                              string.find(text, "upgrade") or
                                              string.find(text, "store") or
                                              string.find(text, "bonus") or
                                              string.find(text, "run")
                            
                            if isRelevant then
                                -- Verifica se o botão é REAL (tamanho adequado e na tela)
                                if isButtonOnScreen(btn) then
                                    local btnId = tostring(btn) .. "_" .. tostring(btn.AbsolutePosition.X)
                                    
                                    -- Evita clicar no mesmo botão várias vezes seguidas
                                    if not clickedButtons[btnId] or tick() - clickedButtons[btnId] > 3 then
                                        local success = clickRealButton(btn)
                                        if success then
                                            clickedButtons[btnId] = tick()
                                            task.wait(0.2)
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    task.wait(0.4) -- Delay maior para não sobrecarregar
                end
            end)
        else
            print("Click Bonus DEACTIVATED")
            clickedButtons = {}
        end
    end
})

