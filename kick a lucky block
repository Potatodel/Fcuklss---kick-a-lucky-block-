-- AUTO KICK AND GET
local autoKickGet = false
TabMain:Toggle({
    Title = "Auto Kick and Get",
    Desc = "Auto farms perfectly",
    Icon = "repeat",
    Default = false,
    Callback = function(state)
        autoKickGet = state
        if state then
            print("Auto Kick and Get ACTIVATED")
            task.spawn(function()
                while autoKickGet do
                    local char, hum, hrp = getCharacter()
                    if hum.Health > 0 then
                        local originalPos = hrp.Position
                        local targetPos = Vector3.new(695.9, 3.0, 221.5)
                        hrp.CFrame = CFrame.new(targetPos)
                        task.wait(0.5)
                        local distance = (hrp.Position - targetPos).Magnitude
                        if distance <= 6 then
                            local args = { [1] = 0.9705939516425133, [2] = 1 }
                            ReplicatedStorage.Shared.Packages.Network.rev_KickEvent:FireServer(unpack(args))
                            task.wait(0.15)
                            ReplicatedStorage.Shared.Packages.Network.rev_KickEvent:FireServer(unpack(args))
                            print("Kick Done!")
                            task.wait(0.3)
                            local returned = safeMoveTo(hum, hrp, originalPos)
                            if returned then
                                print("Returned!")
                            end
                        end
                    end
                    task.wait(1)
                end
            end)
        else
            print("Auto Kick and Get DEACTIVATED")
